# Environment Variables for ChatGLM Medical Model Training
# Copy this file to .env and update paths for your environment

# Data Directories
DATA_INPUT_DIR=/root/autodl-tmp/huatuo-encyclopedia-qa
DATA_OUTPUT_DIR=/root/autodl-tmp/huatuo-encyclopedia-qa-alpaca

# Model Paths
MODEL_PATH=/root/autodl-tmp/models
BASE_MODEL=ZhipuAI/glm-4-9b-chat

# Checkpoint Directories
CHECKPOINT_DIR=/root/autodl-tmp/checkpoints
LORA_OUTPUT_DIR=${CHECKPOINT_DIR}/huatuo-glm-qlora
MERGED_MODEL_DIR=${CHECKPOINT_DIR}/huatuo-glm-qlora-merge

# Training Configuration
MAX_SAMPLES=10000
NUM_EPOCHS=1.0
LEARNING_RATE=1.0e-4

# Inference Configuration
API_PORT=8000
